# Consumed by `pnpm call` (scripts/call-all.ts) only.
# These are NOT the SDK env vars — those live on each platform's own env store
# (Supabase auto-injects; set on Vercel + Cloudflare manually).

SUPABASE_FN_URL=https://<project-ref>.supabase.co/functions/v1/hello
VERCEL_FN_URL=https://<your-vercel-app>.vercel.app/api/hello
CF_FN_URL=https://hello-supabase-server.<your-subdomain>.workers.dev

# Sent in the `apikey` header. Use a publishable key that matches one of the
# values configured on each platform's SUPABASE_PUBLISHABLE_KEY(S).
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
