# Vite embeds these at build time (publishable values only).
# For local dev: copy to .env and fill in.
# For Cloudflare Pages: set as build-time env vars in the project settings.

VITE_SUPABASE_FN_URL=https://<project-ref>.supabase.co/functions/v1/hello
VITE_VERCEL_FN_URL=https://<your-vercel-app>.vercel.app/api/hello
VITE_CF_FN_URL=https://hello-supabase-server.<your-subdomain>.workers.dev

# Supabase project URL — used by supabase-js in the browser for auth + stats query.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Sent in the `apikey` header. Publishable key — safe to ship to the browser.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
