{
  "name": "hello-supabase-server",
  "private": true,
  "version": "0.0.0",
  "description": "One handler, three runtimes: Supabase Edge Functions, Vercel (Bun), Cloudflare Workers — auth via @supabase/server.",
  "scripts": {
    "call": "bun scripts/call-all.ts",
    "deploy:supabase": "pnpm --filter ./apps/supabase run deploy",
    "deploy:vercel": "vercel deploy --prod",
    "deploy:cloudflare": "pnpm --filter ./apps/cloudflare run deploy"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/bun": "^1.1.0",
    "vercel": "^53.2.0"
  },
  "packageManager": "pnpm@10.30.0"
}
