{
  "name": "hello-supabase-server",
  "private": true,
  "version": "0.0.0",
  "description": "One handler, three runtimes: Supabase Edge Functions, Vercel (Bun), Cloudflare Workers — auth via @supabase/server.",
  "scripts": {
    "call": "bun scripts/call-all.ts",
    "deploy:all": "pnpm run --parallel --include-workspace-root \"/^deploy:(supabase|vercel|cloudflare)$/\"",
    "deploy:supabase": "pnpm --filter ./apps/supabase run deploy",
    "deploy:vercel": "vercel deploy --prod",
    "deploy:cloudflare": "pnpm --filter ./apps/cloudflare run deploy",
    "deploy:web": "pnpm --filter ./apps/web run deploy",
    "dev:web": "pnpm --filter ./apps/web run dev"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "typescript": "^5.6.0",
    "vercel": "^53.2.0"
  },
  "packageManager": "pnpm@11.1.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msgpackr-extract",
      "sharp",
      "workerd"
    ]
  }
}
